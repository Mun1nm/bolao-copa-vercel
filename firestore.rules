rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function isLeagueOwner(leagueId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/leagues/$(leagueId)).data.ownerId == request.auth.uid;
    }

    function isActiveMember(leagueId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/leagues/$(leagueId)/members/$(request.auth.uid)).data.status == 'active';
    }

    function isBeforeDeadline(leagueId) {
      let league = get(/databases/$(database)/documents/leagues/$(leagueId));
      return !('deadline' in league.data)
        || league.data.deadline == null
        || request.time < league.data.deadline;
    }

    function isValidScore(value) {
      return value is int && value >= 0 && value <= 99;
    }

    function isValidGuessData(data) {
      return data.keys().hasOnly(['matchId', 'userId', 'leagueId', 'homeGuess', 'awayGuess', 'updatedAt'])
        && data.userId == request.auth.uid
        && data.leagueId is string
        && data.matchId is string
        && isValidScore(data.homeGuess)
        && isValidScore(data.awayGuess);
    }

    // Necessaria para a Home buscar "Meus Boloes" via collectionGroup.
    match /{document=**}/members/{memberId} {
      allow read: if isSignedIn();
    }

    // ---- Leagues ----
    match /leagues/{leagueId} {
      allow read: if true;
      allow create: if isAdmin()
        && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAdmin() || isLeagueOwner(leagueId);

      match /members/{memberId} {
        allow read: if isSignedIn();

        // Usuario comum so cria o proprio pedido como pendente.
        // O dono cria o proprio membro ativo ao criar o bolao.
        allow create: if isSignedIn()
          && memberId == request.auth.uid
          && request.resource.data.uid == request.auth.uid
          && (
            request.resource.data.status == 'pending'
            || (request.resource.data.status == 'active' && isLeagueOwner(leagueId))
          )
          && !request.resource.data.keys().hasAny(['totalPoints', 'exactHits']);

        // Usuario pode sincronizar apenas dados publicos do proprio perfil.
        // Dono/admin pode aprovar/remover status. Admin tambem atualiza ranking.
        allow update: if isAdmin()
          || (
            isLeagueOwner(leagueId)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
          )
          || (
            isSignedIn()
            && memberId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'photoURL', 'email'])
          );

        allow delete: if isAdmin() || isLeagueOwner(leagueId);
      }
    }

    // ---- Guesses (palpites) ----
    match /guesses/{guessId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && isValidGuessData(request.resource.data)
        && isActiveMember(request.resource.data.leagueId)
        && isBeforeDeadline(request.resource.data.leagueId);

      allow update: if isAdmin()
        || (
          isSignedIn()
          && resource.data.userId == request.auth.uid
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.leagueId == resource.data.leagueId
          && request.resource.data.matchId == resource.data.matchId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['homeGuess', 'awayGuess', 'updatedAt'])
          && isValidScore(request.resource.data.homeGuess)
          && isValidScore(request.resource.data.awayGuess)
          && isActiveMember(resource.data.leagueId)
          && isBeforeDeadline(resource.data.leagueId)
        );

      allow delete: if isAdmin();
    }

    // ---- Matches & Teams (read-only para participantes) ----
    match /matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /teams/{teamId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && (!request.resource.data.keys().hasAny(['isAdmin']) || request.resource.data.isAdmin == false);
      allow update: if isSignedIn()
        && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin']);
    }
  }
}
